generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  pending
  paid
  failed
  cancelled
}

enum ActivationCodeStatus {
  available
  reserved
  sold
  blocked
}

enum ActivationCredentialType {
  activation_code
  username_password
}

enum DeliveryStatus {
  delivered
  failed
}

enum SiteTheme {
  orange
  red
}

enum PaymentProvider {
  woovi
  ggpix
}

enum ActivityEventType {
  login
  purchase
  access
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?
  /// CPF do pagador (11 dígitos), opcional — usado para pré-preencher Pix (ex.: GGPIX).
  payerCpf     String?
  passwordHash String
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
  orders       Order[]
  passwordResetTokens PasswordResetToken[]
  activityLogs ActivityLog[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Plan {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  logoDataUrl String?          @db.Text
  durationDays Int
  priceCents  Int
  benefits    String[]
  isActive    Boolean          @default(true)
  isFeatured  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  codes       ActivationCode[]
  orders      Order[]
}

model ActivationCode {
  id             String                   @id @default(cuid())
  code           String                   @unique
  credentialType ActivationCredentialType @default(activation_code)
  username       String?
  password       String?
  status         ActivationCodeStatus     @default(available)
  /// Fim da reserva do Pix (checkout); após expirar, o código volta a `available`.
  reservedUntil  DateTime?
  blockedReason  String?
  planId         String
  orderId        String?                  @unique
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  plan           Plan                     @relation(fields: [planId], references: [id], onDelete: Cascade)
  order          Order?                   @relation(fields: [orderId], references: [id])
  deliveries     Delivery[]

  @@index([planId, status])
}

model Order {
  id              String      @id @default(cuid())
  /// Número amigável sequencial (ex.: #1042) para o cliente e suporte
  orderNumber     Int         @unique @default(autoincrement())
  userId          String
  planId          String
  status          OrderStatus @default(pending)
  amountCents     Int
  wooviChargeId   String?     @unique
  wooviTxid       String?     @unique
  /// correlationID enviado na criação da cobrança Woovi (match no webhook quando txid/chargeId divergem).
  pixCorrelationId String?    @unique
  /// Snapshot de origem da compra (UTM/referrer/landing) no momento da criação.
  attribution     Json?
  attributionSource String?
  attributionMedium String?
  attributionCampaign String?
  attributionReferrer String?
  attributionLandingPath String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  activationCode  ActivationCode?
  delivery        Delivery?
  activityLogs    ActivityLog[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([attributionSource])
  @@index([attributionMedium])
  @@index([attributionCampaign])
}

/// Eventos de uso para mapa de atividade (admin). IP apenas como hash (detecção / agregação).
model ActivityLog {
  id          String            @id @default(cuid())
  userId      String
  orderId     String?
  type        ActivityEventType
  country     String?
  countryCode String?
  city        String?
  lat         Float?
  lng         Float?
  amountCents Int?
  /// SHA-256 com salt (ACTIVITY_IP_SALT) — agrupa mesma origem sem guardar IP em claro
  ipHash      String?
  userAgent   String?           @db.VarChar(512)
  createdAt   DateTime          @default(now())
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([countryCode])
  @@index([ipHash, createdAt])
}

model Delivery {
  id              String         @id @default(cuid())
  orderId          String         @unique
  activationCodeId String
  status           DeliveryStatus @default(delivered)
  deliveredAt      DateTime       @default(now())
  message          String?
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  activationCode   ActivationCode @relation(fields: [activationCodeId], references: [id], onDelete: Restrict)
}

model WebhookLog {
  id         String   @id @default(cuid())
  eventId    String   @unique
  eventType  String
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  resource    String
  metadata    Json?
  createdAt   DateTime @default(now())
}

/// Identidade visual da loja (singleton: id = "default")
model SiteBranding {
  id               String    @id @default("default")
  logoDataUrl      String?   @db.Text
  faviconDataUrl   String?   @db.Text
  storeDisplayName String    @default("Loja Nova")
  activeTheme      SiteTheme @default(orange)
  landingCopy      Json?
  updatedAt        DateTime  @updatedAt
}

/// Configurações globais de contato (singleton: id = "default")
model AppSettings {
  id              String   @id @default("default")
  whatsappEnabled Boolean  @default(false)
  whatsappNumber  String?
  whatsappMessage String?
  whatsappLabel   String?
  /// Envia credencial de ativação via WhatsApp (Twilio) após pagamento confirmado.
  whatsappDeliveryEnabled Boolean @default(false)
  /// Template opcional para mensagem de entrega via WhatsApp.
  whatsappDeliveryTemplate String? @db.Text
  paymentProvider PaymentProvider @default(woovi)
  wooviApiKey     String?  @db.Text
  wooviWebhookSecret String? @db.Text
  ggpixApiKey     String?  @db.Text
  ggpixWebhookSecret String? @db.Text
  /// Token Bearer enviado em Authorization quando o painel GGPIX está em "Ambos" (Bearer + HMAC).
  ggpixWebhookBearer String? @db.Text
  /// Alerta por e-mail quando estoque (cód disponíveis) de planos ativos ≤ limite
  lowStockAlertEnabled     Boolean   @default(false)
  lowStockThreshold        Int       @default(5)
  lowStockNotifyEmail      String?
  lowStockAlertLastSentAt  DateTime?
  updatedAt       DateTime @updatedAt
}
